# Puerto interno en el que el gateway levanta NestJS.
PORT=3000

# Lista de origenes permitidos para CORS separada por comas.
FRONTENDS_SERVERS="http://localhost:3001,http://localhost:3002"

# URL base de la integracion PVT BE.
PVT_BE_API_SERVER="http://localhost:<port>"
# URL base del backend PVT usado por prestamos y otras consultas.
PVT_BACKEND_API_SERVER="http://localhost:<port>"

# Secreto con el que se valida el token hash de peticiones PVT.
PVT_HASH_SECRET="secret"

# Host del servidor FTP que usa el gateway para gestionar archivos.
FTP_HOST=192.168.2.000
# Usuario con el que el gateway autentica la sesion FTP.
FTP_USERNAME=test_pruebas
# Contrasena usada para abrir la conexion FTP.
FTP_PASSWORD=test
# Ruta raiz sobre la que el gateway construye operaciones de archivos.
FTP_ROOT="/test_pruebas"
# Indica si la conexion FTP debe usar SSL.
FTP_SSL=false

# URL base del proveedor SMS.
SMS_SERVER_URL="http://172.16.1.XX/goip/en"
# Usuario o identificador esperado por el proveedor SMS.
SMS_SERVER_ROOT="root"
# Contrasena que el gateway envia al proveedor SMS.
SMS_SERVER_PASSWORD="TEST1234"
# Identificador del proveedor o canal SMS.
SMS_PROVIDER="1"

# URL base del integrador de WhatsApp.
WHATSAPP_SERVER_URL=""

# URL base del proveedor OAuth de ciudadania digital.
CITIZENSHIP_DIGITAL_CLIENT_URL="https://proveedor.bo"
# Identificador del cliente registrado ante ciudadania digital.
CITIZENSHIP_DIGITAL_CLIENT_ID="YYYYYYYYYYYYYYYY"
# Redirect URI usada en el flujo OAuth de ciudadania digital.
CITIZENSHIP_DIGITAL_REDIRECT_URI="com.YYYYYY.pvt:/"
# Scopes solicitados al proveedor de ciudadania digital.
CITIZENSHIP_DIGITAL_SCOPES="openid profile fecha_nacimiento email celular offline_access"

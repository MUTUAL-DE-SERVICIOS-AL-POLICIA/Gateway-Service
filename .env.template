# ============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - Gateway-Service
# ============================================================================

# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Actualiza los valores según tu entorno


# SERVER CONFIGURATION

# PORT - PUERTO DEL SERVICIO GATEWAY
# Define en qué puerto TCP se ejecutará el Gateway (punto de entrada de la plataforma)
PORT=3000

# ENVIRONMENT - Ambiente de ejecución
# Valores: dev (desarrollo), prod (producción)
# Afecta logs, validaciones y comportamiento de la aplicación
ENVIRONMENT=dev


# MESSAGE BROKER - NATS

# NATS_SERVERS - URL del servidor NATS
# NATS es un bus de mensajes que permite comunicación asincrónica entre microservicios.
NATS_SERVERS="nats://localhost:4222"


# FRONTEND CONFIGURATION

# FRONTENDS_SERVERS - URLs de los servidores Frontend
# Lista de frontends que pueden acceder al Gateway
FRONTENDS_SERVERS="http://localhost:3001,http://localhost:3002"


# EXTERNAL SERVICES - APIs PRIVADAS (Backend Privado)

# PVT_BE_API_SERVER - URL del servidor backend privado
# Endpoint principal para comunicación con sistemas backend privados
# Ejemplo: http://192.168.1.100:8080
PVT_BE_API_SERVER="http://localhost:<port>"

# PVT_BACKEND_API_SERVER - URL alternativa del servidor backend privado
# Endpoint secundario (fallback) para comunicación con sistemas backend privados
# Ejemplo: http://192.168.1.101:8080
PVT_BACKEND_API_SERVER="http://localhost:<port>"

# PVT_HASH_SECRET - Clave secreta para comunicación con backend privado
PVT_HASH_SECRET="your_pvt_hash_secret"


# DATABASE CONFIGURATION - POSTGRESQL

# DB_HOST - DIRECCIÓN DEL SERVIDOR POSTGRES
DB_HOST=192.168.X.XXX

# DB_PORT - PUERTO DONDE POSTGRESQL ESCUCHA
DB_PORT=5432

# DB_USERNAME - USUARIO DE POSTGRESQL
DB_USERNAME=postgres

# DB_PASSWORD - CONTRASEÑA DEL USUARIO DE POSTGRESQL
DB_PASSWORD=999999

# DB_DATABASE - NOMBRE DE LA BASE DE DATOS
DB_DATABASE=platform

# DB_SCHEMA - Schema de PostgreSQL
DB_SCHEMA=public

# DB_SYNCHRONIZE - Sincronización automática de esquema
#   Si es TRUE: TypeORM sincroniza automáticamente la estructura de la base de datos
#               con las entidades de código (crea/modifica tablas automáticamente)
#   Si es FALSE: NO sincroniza automáticamente. Necesita crear migraciones manuales para cambios
DB_SYNCHRONIZE=false


# FTP SERVER CONFIGURATION

# FTP_HOST - Dirección del servidor FTP
# Servidor donde se almacenan archivos de usuarios
FTP_HOST=192.168.X.XXX

# FTP_USERNAME - Usuario para conectarse a FTP
FTP_USERNAME=user

# FTP_PASSWORD - Contraseña para conectarse a FTP
FTP_PASSWORD=password

# FTP_ROOT - Ruta raíz en el servidor FTP
# Ruta base donde se almacenan los archivos
FTP_ROOT="/path/"

# FTP_SSL - Usar conexión segura SSL/TLS con FTP
# TRUE: usa FTPS (FTP seguro)
# FALSE: usa FTP simple
FTP_SSL=false


# SMS SERVICE CONFIGURATION

# SMS_SERVER_URL - URL del servidor SMS
# Endpoint del proveedor SMS para enviar mensajes
SMS_SERVER_URL="http://192.168.X.X/goip/en/"

# SMS_SERVER_ROOT - Usuario/credencial del servidor SMS
# Usuario con permisos para enviar SMS
SMS_SERVER_ROOT=root

# SMS_SERVER_PASSWORD - Contraseña del servidor SMS
SMS_SERVER_PASSWORD=password

# SMS_PROVIDER - ID del proveedor SMS
# Identificador del proveedor SMS a utilizar (puede variar por región)
SMS_PROVIDER=1


# WHATSAPP SERVICE CONFIGURATION

# WHATSAPP_SERVER_URL - URL del servidor WhatsApp
# Ejemplo: https://api.whatsapp.com/send, http://whatsapp-api.local:3000
# Dejar en blanco si no se usa WhatsApp
WHATSAPP_SERVER_URL=""


# CITIZENSHIP DIGITAL INTEGRATION

# CITIZENSHIP_DIGITAL_CLIENT_URL - URL del proveedor de Ciudadanía Digital
CITIZENSHIP_DIGITAL_CLIENT_URL="https://proveedor.bo"

# CITIZENSHIP_DIGITAL_CLIENT_ID - ID de aplicación en Ciudadanía Digital
# Credencial asignada por el proveedor
CITIZENSHIP_DIGITAL_CLIENT_ID="client_id"

# CITIZENSHIP_DIGITAL_REDIRECT_URI - URI de redirección después de autenticación
CITIZENSHIP_DIGITAL_REDIRECT_URI="app://"

# CITIZENSHIP_DIGITAL_SCOPES - Permisos solicitados a Ciudadanía Digital
# Espacios separados listando qué datos del usuario se necesitan
# Valores comunes: openid (ID), profile (perfil), email (correo)
CITIZENSHIP_DIGITAL_SCOPES="openid profile email"